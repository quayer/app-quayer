# ==========================================
# 🧪 QUAYER HOMOL - ENVIRONMENT TEMPLATE
# ==========================================
# Copie este arquivo para .env.homol no servidor 167.235.139.140
# em /opt/quayer-homol/.env e edite com valores reais.
#
# NUNCA commitar .env.homol — apenas .env.homol.example.

# ===========================================
# 🌍 APP
# ===========================================
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://homol.quayer.com
PORT=3000
HOSTNAME=0.0.0.0

# ===========================================
# ☁️ CLOUDFLARE TUNNEL
# ===========================================
# Token gerado via API CF: GET /accounts/{acct}/cfd_tunnel/{id}/token
# Tunnel ID atual (homol-quayer): __consultar_no_painel_cloudflare__
# NUNCA commitar este valor real — está em GitHub Secret CF_TUNNEL_HOMOL_TOKEN
CF_TUNNEL_HOMOL_TOKEN=__obter_via_github_secret__

# ===========================================
# 🗄️ DATABASE (Postgres em container homol)
# ===========================================
DB_NAME=quayer_homol
DB_USER=quayer_homol
DB_PASSWORD=__GERAR_VIA_openssl_rand__
DATABASE_URL=postgresql://quayer_homol:__SENHA__@homol-quayer-postgres:5432/quayer_homol?schema=public
DIRECT_DATABASE_URL=postgresql://quayer_homol:__SENHA__@homol-quayer-postgres:5432/quayer_homol?schema=public

# ===========================================
# 🔴 REDIS (em container homol)
# ===========================================
REDIS_URL=redis://homol-quayer-redis:6379
REDIS_HOST=homol-quayer-redis
REDIS_PORT=6379

# ===========================================
# 👑 ADMIN INICIAL (criado no primeiro boot via create-admin.js)
# ===========================================
ADMIN_EMAIL=__definir_no_primeiro_deploy__
ADMIN_NAME=__definir_no_primeiro_deploy__

# ===========================================
# 🔑 SEGREDOS — gerar com: openssl rand -base64 32
# ===========================================
JWT_SECRET=__GERAR__
JWT_REFRESH_SECRET=__GERAR__
JWT_MAGIC_LINK_SECRET=__GERAR__
JWT_2FA_CHALLENGE_SECRET=__GERAR__
IGNITER_APP_SECRET=__GERAR__
ENCRYPTION_KEY=__GERAR__
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# ===========================================
# 📧 EMAIL
# ===========================================
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply-homol@quayer.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ===========================================
# 📱 WHATSAPP / UAZ
# ===========================================
UAZAPI_URL=https://quayer.uazapi.com
UAZAPI_ADMIN_TOKEN=
UAZAPI_WEBHOOK_URL=https://homol.quayer.com/api/v1/webhooks/uaz

# ===========================================
# 🤖 OPENAI
# ===========================================
OPENAI_API_KEY=

# ===========================================
# 🔐 GOOGLE OAUTH (homol tem redirect URI próprio)
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://homol.quayer.com/api/v1/auth/google/callback

# ===========================================
# 📦 SUPABASE (Storage opcional — buckets prefixados)
# ===========================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET_MEDIA=homol-media-whatsapp
SUPABASE_STORAGE_BUCKET_PROFILES=homol-profile-pictures
SUPABASE_STORAGE_BUCKET_ATTACHMENTS=homol-attachments
