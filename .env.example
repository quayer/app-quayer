# ===========================================
# 🔐 QUAYER - CONFIGURAÇÃO DE AMBIENTE
# ===========================================
# IMPORTANTE: Copie este arquivo para .env e configure os valores
# Comando: cp .env.example .env
#
# Documentação completa: docs/DEPLOYMENT_GUIDE.md

# ===========================================
# 🌍 APLICAÇÃO
# ===========================================
NODE_ENV=development                    # development | production | test
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# ===========================================
# 🔧 IGNITER.JS FRAMEWORK
# ===========================================
# Nome da aplicação
IGNITER_APP_NAME=quayer

# URL onde a API estará rodando
NEXT_PUBLIC_IGNITER_API_URL=http://localhost:3000/

# Path base da API
NEXT_PUBLIC_IGNITER_API_BASE_PATH=/api/v1

# Secret key para Igniter.js (OBRIGATÓRIO em produção)
# Gerar: openssl rand -base64 32
IGNITER_APP_SECRET=your_random_secret_key_here_change_in_production

# Job queue prefix
IGNITER_JOBS_QUEUE_PREFIX=igniter

# MCP server base path
IGNITER_MCP_SERVER_BASE_PATH=/api/mcp

# MCP session timeout in ms (1 hour)
IGNITER_MCP_SERVER_TIMEOUT=3600000

# Logging level
IGNITER_LOG_LEVEL=info                  # debug | info | warn | error

# Telemetry (Igniter.js observability)
IGNITER_TELEMETRY_ENABLE_TRACING=true
IGNITER_TELEMETRY_ENABLE_METRICS=true
IGNITER_TELEMETRY_ENABLE_EVENTS=true
IGNITER_TELEMETRY_ENABLE_CLI_INTEGRATION=true

# ===========================================
# 🔑 SEGURANÇA & AUTENTICAÇÃO
# ===========================================
# OBRIGATÓRIO: Chave secreta JWT (mínimo 32 caracteres)
# Gerar: openssl rand -base64 32
JWT_SECRET=change_me_to_random_64_chars

# Tempo de expiração dos tokens
JWT_ACCESS_TOKEN_EXPIRES_IN=15m         # Access token (15 minutos)
JWT_REFRESH_TOKEN_EXPIRES_IN=7d         # Refresh token (7 dias)

# ===========================================
# 🗄️ DATABASE (PostgreSQL)
# ===========================================
# OBRIGATÓRIO: Connection string completa
# Formato: postgresql://user:password@host:port/database?schema=public
#
# --- Modo Local (Docker Compose) ---
DATABASE_URL=postgresql://docker:docker@localhost:5432/docker?schema=public

# Conexão direta (sem pooler) — usada pelo Prisma Migrate
# Em dev local: igual ao DATABASE_URL
# Com Supabase: usa conexão direta (não o pooler)
DIRECT_DATABASE_URL=postgresql://docker:docker@localhost:5432/docker?schema=public

# Configurações individuais (usadas pelo Docker Compose)
DB_NAME=docker
DB_USER=docker
DB_PASSWORD=docker
DB_HOST=localhost
DB_PORT=5432

# Shadow Database (usado pelo Prisma Migrate)
SHADOW_DATABASE_URL=postgresql://docker:docker@localhost:5432/docker_shadow?schema=public

# --- Modo Supabase (Produção) ---
# 1. Crie um projeto em https://supabase.com/dashboard
# 2. Vá em Settings > Database > Connection string
# 3. Use o Session Pooler para DATABASE_URL (app queries)
# 4. Use a conexão direta para DIRECT_DATABASE_URL (migrations)
#
# DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
# DIRECT_DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ===========================================
# 🔴 REDIS (Cache & Queue)
# ===========================================
# OBRIGATÓRIO: Connection string do Redis
REDIS_URL=redis://localhost:6379

# Configurações individuais
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                         # Opcional em dev, obrigatório em prod
REDIS_DB=0                              # Database index (0-15)

# Redis TLS (Produção)
# REDIS_URL=rediss://default:password@redis.upstash.io:6379

# ===========================================
# 📧 EMAIL SERVICE
# ===========================================
# Provedor de email: mock | resend | smtp
# - mock: Apenas loga no console (desenvolvimento)
# - resend: Serviço Resend (recomendado para produção)
# - smtp: SMTP genérico (Gmail, Outlook, etc)
EMAIL_PROVIDER=mock

# Email remetente padrão
EMAIL_FROM=noreply@quayer.com

# --- Resend (Recomendado para produção) ---
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=

# --- SMTP (Gmail, Outlook, Mailgun, etc) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false                       # true para porta 465, false para 587
SMTP_USER=
SMTP_PASS=

# ===========================================
# 📱 WHATSAPP (UAZ API)
# ===========================================
# OBRIGATÓRIO: URL base da API UAZ
UAZAPI_URL=https://quayer.uazapi.com

# OBRIGATÓRIO: Token admin para criar/deletar instâncias
# Obtenha em: https://uazapi.com/dashboard
UAZAPI_ADMIN_TOKEN=

# Token padrão (fallback)
UAZAPI_TOKEN=

# ===========================================
# 🔐 GOOGLE OAUTH (Opcional)
# ===========================================
# OAuth Client ID e Secret
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redirect URI para callback OAuth
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

# ===========================================
# 📦 SUPABASE (Storage, Realtime, Infra)
# ===========================================
# Projeto Supabase — obtenha em: https://supabase.com/dashboard > Settings > API
# OBRIGATÓRIO quando usar Supabase Storage ou Realtime
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Buckets de Storage (criados automaticamente se não existirem)
# media-whatsapp: mídias de conversas WhatsApp
# profile-pictures: fotos de perfil de contatos
# attachments: arquivos enviados pelo painel
SUPABASE_STORAGE_BUCKET_MEDIA=media-whatsapp
SUPABASE_STORAGE_BUCKET_PROFILES=profile-pictures
SUPABASE_STORAGE_BUCKET_ATTACHMENTS=attachments

# Expiração de signed URLs (em segundos, default: 7 dias)
SUPABASE_STORAGE_SIGNED_URL_EXPIRY=604800

# ===========================================
# 🚦 RATE LIMITING (Upstash Redis)
# ===========================================
# Opcional: Upstash Redis REST API para rate limiting distribuído
# Obtenha em: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===========================================
# 📊 MONITORAMENTO & LOGS
# ===========================================
# Opcional: Sentry para error tracking
# Obtenha em: https://sentry.io/
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Nível de log da aplicação
LOG_LEVEL=info                          # debug | info | warn | error

# ===========================================
# 🚀 DEPLOY (CI/CD)
# ===========================================
# --- Vercel ---
# Obtenha em: https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# --- Easypanel ---
# Obtenha em: Easypanel Dashboard > API Settings
EASYPANEL_API_KEY=
EASYPANEL_PROJECT_NAME=quayer-app
EASYPANEL_SERVICE_NAME=app

# --- GitHub ---
# Para CI/CD automation
GITHUB_TOKEN=                           # Configurar no GitHub Secrets

# ===========================================
# 🧪 TESTING
# ===========================================
# Banco de dados para testes (isolado)
TEST_DATABASE_URL=postgresql://docker:docker@localhost:5432/docker_test?schema=public

# URL base para testes E2E (Playwright)
BASE_URL=http://localhost:3000

# Playwright
PLAYWRIGHT_BROWSERS_PATH=0              # Usa browsers do sistema

# ===========================================
# 🔧 DESENVOLVIMENTO
# ===========================================
# Next.js
NEXT_TELEMETRY_DISABLED=1               # Desabilita telemetria do Next.js

# Prisma
PRISMA_HIDE_UPDATE_MESSAGE=true         # Oculta mensagens de update do Prisma

# ===========================================
# 🌐 PRODUÇÃO - VARIÁVEIS ADICIONAIS
# ===========================================
# Em produção, configure também:
#
# 1. Database com connection pooling:
#    DATABASE_URL=postgresql://user:pass@pooler:6543/db?pgbouncer=true
#
# 2. Redis com TLS:
#    REDIS_URL=rediss://default:pass@redis.upstash.io:6379
#
# 3. Email provider real:
#    EMAIL_PROVIDER=resend
#    RESEND_API_KEY=re_xxxxx
#
# 4. Secrets únicos:
#    JWT_SECRET=$(openssl rand -base64 32)
#    IGNITER_APP_SECRET=$(openssl rand -base64 32)
#
# 5. Monitoramento:
#    SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
#
# 6. Rate limiting:
#    UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
#    UPSTASH_REDIS_REST_TOKEN=xxxxx

# ============================================
# Billing — Gateway Mode
# ============================================
# EFI_ONLY: Efí for payments, no NFS-e
# ASAAS_ONLY: Asaas for payments + NFS-e
# HYBRID: Efí for payments, Asaas for NFS-e
BILLING_GATEWAY_MODE=HYBRID

# ============================================
# Billing — Efí Bank (Pix Automático)
# ============================================
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_PIX_KEY=
EFI_CERTIFICATE_PATH=./certs/efi-prod.p12
EFI_SANDBOX=true
EFI_WEBHOOK_SECRET=
EFI_BANK_ACCOUNT=
EFI_BANK_AGENCY=
EFI_ACCOUNT_TYPE=CACC

# ============================================
# Billing — Asaas (NFS-e)
# ============================================
ASAAS_API_KEY=
ASAAS_SANDBOX=true
ASAAS_MUNICIPAL_SERVICE_ID=
ASAAS_WEBHOOK_TOKEN=

# ===========================================
# 🧰 Builder tools
# ===========================================
# Tavily Search API — used by the Builder meta-agent `search_web` tool (US-014)
# Obtenha em: https://tavily.com/
TAVILY_API_KEY=

# ===========================================
# 📝 NOTAS IMPORTANTES
# ===========================================
# 1. NUNCA commite o arquivo .env no Git
# 2. Use secrets do GitHub Actions para CI/CD
# 3. Gere JWT_SECRET e IGNITER_APP_SECRET únicos para produção
# 4. Configure CORS e rate limiting adequadamente em produção
# 5. Use connection pooling para DATABASE_URL em produção
# 6. Habilite TLS/SSL para Redis e PostgreSQL em produção
# 7. Configure backup automático do banco de dados
# 8. Monitore uso de recursos (CPU, memória, disco)
# 9. Configure logs centralizados (ex: Datadog, Logtail)
# 10. Teste recuperação de desastres regularmente
#
# 📖 Documentação completa: docs/DEPLOYMENT_GUIDE.md
