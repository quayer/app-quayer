{
  "name": "sample-next-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run test/unit",
    "test:unit:watch": "vitest test/unit",
    "test:unit:coverage": "vitest run test/unit --coverage",
    "test:api": "vitest run test/api",
    "test:api:watch": "vitest test/api",
    "test:integration": "vitest run test/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:unit && npm run test:api && npm run test:e2e",
    "test:ci": "npm run lint && npm run test:unit:coverage && npm run test:api && npm run build",
    "test:real": "vitest run test/real --reporter=verbose",
    "test:real:api": "vitest run test/real/integration --reporter=verbose",
    "test:real:ui": "playwright test test/real/ui --reporter=list",
    "test:real:e2e": "playwright test test/real/e2e --reporter=list",
    "test:real:edge": "vitest run test/real/edge-cases --reporter=verbose",
    "test:real:advanced": "vitest run test/real/advanced --reporter=verbose",
    "test:real:journey:signup": "playwright test test/real/e2e/journey-signup-login-real.test.ts --reporter=list --headed",
    "test:real:journey:organization": "playwright test test/real/e2e/journey-organization-invite-real.test.ts --reporter=list --headed",
    "test:real:journey:whatsapp": "playwright test test/real/e2e/journey-whatsapp-complete-real.test.ts --reporter=list --headed",
    "test:real:journey:onboarding": "playwright test test/real/e2e/journey-onboarding-complete-real.test.ts --reporter=list --headed",
    "test:real:journey:multiuser": "playwright test test/real/e2e/journey-multiuser-collaboration-real.test.ts --reporter=list --headed",
    "test:admin": "playwright test test/real/admin --reporter=list --headed",
    "test:admin:complete": "playwright test test/real/admin/admin-complete-validation.test.ts --reporter=list --headed --workers=1",
    "test:uazapi": "playwright test test/real/uazapi --reporter=list --headed",
    "test:real:all": "npm run test:real:api && npm run test:real:ui && npm run test:real:e2e && npm run test:real:edge && npm run test:real:advanced && npm run test:admin && npm run test:uazapi",
    "test:massive": "playwright test test/real/admin/admin-complete-validation.test.ts --reporter=html --headed --workers=1",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset && npm run db:seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
